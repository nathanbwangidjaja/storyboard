# Copy this file to .env or .env.local and fill in your values.
# Both .env and .env.local work the same for this project.
# DO NOT commit .env or .env.local — they contain secrets.

DATABASE_URL="file:./dev.db"
NEXTAUTH_SECRET="generate-a-long-random-string-for-production"
NEXTAUTH_URL="http://localhost:3000"
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-flash-image"
